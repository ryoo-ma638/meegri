# このファイルをコピーして「.env」を作り、自分のキーを入れてください。
#  cp .env.example .env
# ※ .env は .gitignore 済み（GitHubに上がりません）。キーは絶対に公開しないこと。
#
# Gemini APIキーの無料取得: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 使うモデル（無料枠で十分。必要なら変更可: gemini-2.5-flash / gemini-2.0-flash など）
GEMINI_MODEL=gemini-2.5-flash

# オーナーコード（任意・無制限モード用。各自の値に）
OWNER_CODE=
